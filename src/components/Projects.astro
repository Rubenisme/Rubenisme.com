---
import ProjectCard from './ProjectCard.astro';

const projects = [
  {
    name: 'Unscrambler',
    description: 'NS train station anagram unscrambler — enter scrambled letters and find which Dutch station matches.',
    status: 'built' as const,
    url: 'https://github.com/Rubenisme/Unscrambler',
  },
  {
    name: 'Audio Looper',
    description: 'Turn any song into a smooth, long-form audio loop — analyzes waveform structure to find seamless loop points.',
    status: 'built' as const,
    url: 'https://github.com/Rubenisme/audiolooper',
  },
  {
    name: 'Project Three',
    description: 'Short description of this project.',
    status: 'built' as const,
    isPrivate: true,
  },
  {
    name: 'Project Four',
    description: 'Short description of this project.',
    status: 'built' as const,
    isPrivate: true,
  },
  {
    name: 'This Website',
    description: 'Personal portfolio built with Astro + Bun, featuring a boat cursor with canvas wake trail and a 3-theme switcher.',
    status: 'in-progress' as const,
    url: 'https://github.com/Rubenisme',
  },
  {
    name: 'Project Six',
    description: 'Short description of this project.',
    status: 'in-progress' as const,
    isPrivate: true,
  },
  {
    name: 'Project Seven',
    description: 'Short description of this project.',
    status: 'in-progress' as const,
    isPrivate: true,
  },
  {
    name: 'Project Eight',
    description: 'Short description of this project.',
    status: 'in-progress' as const,
    isPrivate: true,
  },
];
---

<section id="projects">
  <div class="container">
    <h2>Projects</h2>
    <div class="grid">
      {projects.map(p => <ProjectCard {...p} />)}
    </div>
  </div>
</section>

<style>
  section {
    padding: 6rem 2rem;
    background: var(--bg-alt);
  }

  .container {
    max-width: 1100px;
    margin: 0 auto;
  }

  h2 {
    font-size: 2rem;
    font-weight: 700;
    color: var(--text-heading);
    margin-bottom: 3rem;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  @media (max-width: 640px) {
    .grid { grid-template-columns: 1fr; }
  }
</style>
