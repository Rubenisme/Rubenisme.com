---
import ProjectCard from './ProjectCard.astro';

const projects = [
  {
    name: 'Unscrambler',
    description: 'NS train station anagram unscrambler — enter scrambled letters and find which Dutch station matches.',
    status: 'built' as const,
    url: 'https://github.com/Rubenisme/Unscrambler',
  },
  {
    name: 'Audio Looper',
    description: 'Turn any song into a smooth, long-form audio loop — analyzes waveform structure to find seamless loop points.',
    status: 'built' as const,
    url: 'https://github.com/Rubenisme/audiolooper',
  },
  {
    name: 'This Website!',
    description: 'Personal portfolio built with Astro + Bun, featuring a boat cursor with canvas wake trail and a 3-theme switcher.',
    status: 'built' as const,
    url: 'https://github.com/Rubenisme/Rubenisme.com',
  },
  {
    name: 'Resume builder',
    description: 'Builds a resume from JSON data. Public soon...',
    status: 'built' as const,
    isPrivate: true,
  },
  {
    name: 'RL Surf learner',
    description: 'Uses C# client and a Python brain with Stable Baselines3 (SB3) to learn how to surf (Edge browser game).',
    status: 'in-progress' as const,
    isPrivate: true,
  },
  {
    name: 'Project Six',
    description: 'God built Isaac, yet he\'s still a work in-progress, and always a mystery.',
    status: 'built' as const,
    isPrivate: true,
  },
  {
    name: 'Project Seven',
    description: 'Advanced language learning system with BKT (Bayesian knowledge/mastery tracer/estimation).',
    status: 'in-progress' as const,
    isPrivate: true,
  },
  {
    name: 'QromGuard',
    description: 'Threat interception for crypto transactions. (Team project — contributed CI/CD pipeline.)',
    url: 'https://qromguard.com/',
    status: 'built' as const,
  },
];
---

<section id="projects">
  <div class="container">
    <h2>Projects</h2>
    <div class="grid">
      {projects.map(p => <ProjectCard {...p} />)}
    </div>
  </div>
</section>

<style>
  section {
    padding: 6rem 2rem;
    background: var(--bg-alt);
  }

  .container {
    max-width: 1100px;
    margin: 0 auto;
  }

  h2 {
    font-size: 2rem;
    font-weight: 700;
    color: var(--text-heading);
    margin-bottom: 3rem;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
  }

  @media (max-width: 640px) {
    .grid { grid-template-columns: 1fr; }
  }
</style>
